# accesorios.caballosrevelo.com — microservicio de pagos OpenPay
# Copiar a $VH_ROOT/.env (fuera de public_html)
# Documentación: README.md y docs/openpay-arquitectura.md

SITE_NAME=Caballos Revelo — Pagos
SITE_URL=https://accesorios.caballosrevelo.com

TIMEZONE=America/Bogota
DEBUG_MODE=false
DISPLAY_ERRORS=false

OPENPAY_WEBHOOK_USER=cr_webhook_sandbox
OPENPAY_WEBHOOK_PASSWORD=CAMBIA_PASSWORD

OPENPAY_RETURN_URL=https://accesorios.caballosrevelo.com/openpay/success.php

# Producción (recomendado):
OPENPAY_WEBHOOK_FORWARD_URL=https://caballosrevelo.com/openpay/webhook.bridge.php
OPENPAY_STATUS_API_URL=https://caballosrevelo.com/openpay/status.bridge.php

# Desarrollo local con ngrok (NO usar en producción):
# OPENPAY_WEBHOOK_FORWARD_URL=https://TU-NGROK.ngrok-free.dev/openpay/webhook.bridge.php
# OPENPAY_STATUS_API_URL=https://TU-NGROK.ngrok-free.dev/openpay/status.bridge.php

# Mismo valor EXACTO en caballosrevelo.com (.env-cr) y aquí:
OPENPAY_BRIDGE_SECRET=MISMO_SECRETO_QUE_EN_CABALLOSREVELO_COM
OPENPAY_STATUS_TOKEN=MISMO_TOKEN_QUE_EN_CABALLOSREVELO_COM

# Mismo Pixel ID que caballosrevelo.com (.env-cr) — solo PageView/Purchase en navegador
META_PIXEL_ID=2058534878012983

# Archivos JSON bajo public_html/openpay/webhooks/ (protegidos con .htaccess):
# Todos los eventos excepto verification → processed/ o error/ (auditoría; no se borran)
